  "acceptance_criteria": [
    "Run logs are written under the XDG data location using `FR-<8hex>` identifiers and `version: 1` records.",
    "Initial, incremental, final, and crashed run-log writes follow the atomic rewrite protocol in the spec.",
    "`runs list` supports limit, since, command, and status filtering while skipping unknown-version files with warnings.",
    "`runs show` supports raw JSON output and live tailing for in-progress runs until `finished_at` is set."
  ],
